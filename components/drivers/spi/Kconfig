            bool "Enable SPI bit-bang operation functions"
            default n

        menuconfig RT_USING_SOFT_SPI
            bool "Use GPIO to simulate SPI (swspi)"
            default n
            select RT_USING_PIN
            select RT_USING_SPI_BITOPS
            if RT_USING_SOFT_SPI
                config RT_SOFT_SPI0_HAS_PIN_DEFAULT
                    bool

