menuconfig RT_USING_SPI
    bool "Using SPI Bus/Device device drivers"
    default n

    if RT_USING_SPI

        menuconfig RT_USING_SPI_ISR
            bool "Enable interrupt-safe SPI operations (using spinlocks in ISR context)"
            default y
        
