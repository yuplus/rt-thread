                            default n

                        config BSP_USING_TIM1_PWM_CH3
                            bool "Using TIM1 channel 3"

                        config BSP_USING_TIM1_PWM_CH4
                            bool "Using TIM1 channel 4"
                    endif

                    if BSP_USING_TIM1_CLOCK_TIMER && BSP_USING_TIM1_PWM
                        comment "BSP_USING_TIM1_CLOCK_TIMER and BSP_USING_TIM1_PWM can only be chosen for one!"
                    endif

                endif

            config BSP_USING_TIM2
                    bool "Using TIM2"
